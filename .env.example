# Vercel / local: copy to .env (not committed)

# InstantDB (server verifies Bearer tokens from the extension)
INSTANT_APP_ID=
INSTANT_APP_ADMIN_TOKEN=

# Upstash Redis (usage, tier cache, price cache, history)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Gemini (Pro/Max AI analysis only)
GEMINI_API_KEY=
# Optional; default in code is gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash-lite

# SerpAPI — required for shopping results (Lite cache + Pro/Max live)
SERPAPI_KEY=

# Optional
# API_ALLOW_ORIGIN=*

# Local dev only: simulate tier without Redis subscription (send X-Dev-Tier / X-Dev-User-Id)
# AUTH_DEV_MODE=1
